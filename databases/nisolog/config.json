{
  "name": "nisolog",
  "system_prompt": "You are a helpful assistant. Use saved memories when they are relevant and avoid inventing facts.",
  "style": "friendly",
  "memory_policy": {
    "auto_save": true,
    "max_context_messages": 10
  },
  "allowed_tools": [
    "save_memory"
  ],
  "rag": {
    "enabled": false,
    "embedding_model": "bge-m3",
    "chunk_size": 500,
    "chunk_overlap": 50,
    "retrieval_k": 4,
    "score_threshold": 0.3
  }
}
